# Copy this file to .env and fill in your values.
# NEVER commit .env to Git.

# Redis — for local dev, run: docker run -p 6379:6379 redis
# On Railway this is injected automatically by the Redis plugin
REDIS_URL=redis://localhost:6379

# Optional: override the EB API base URL
# API_BASE_URL=https://eu-api.empathicbuilding.com
